# Copie para .env e ajuste. NUNCA versione o .env (já está no .gitignore).

# Ambiente: "development" (padrão) ou "production".
# Em production, SECRET_KEY é OBRIGATÓRIA (a app aborta sem ela).
FLASK_ENV=development

# Liga o debugger do Werkzeug. Use 1 só em dev — em produção expõe RCE.
FLASK_DEBUG=0

# Porta do servidor de desenvolvimento.
PORT=5000

# Chave de assinatura de sessão/CSRF. Gere uma forte, por exemplo:
#   python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=

# Chave para criptografar o CPF em repouso (LGPD). OBRIGATÓRIA em produção.
# Gere com:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# ATENÇÃO: se trocar/perder esta chave, os CPFs já gravados ficam ilegíveis.
CPF_ENC_KEY=

# Banco de dados. Padrão: SQLite em instance/ir_traders.db.
# Para PostgreSQL: postgresql+psycopg2://usuario:senha@host:5432/ir_traders
# DATABASE_URL=

# Rate limiting (Flask-Limiter). Em produção use Redis p/ múltiplos workers:
#   redis://localhost:6379
RATELIMIT_STORAGE_URI=memory://

# --- Integração B3 (Área do Investidor) — opcional/futuro ---
B3_ENABLED=0
B3_API_BASE_URL=https://investidor.b3.com.br/api/v1
B3_CLIENT_ID=
B3_CLIENT_SECRET=

# --- Cotações (brapi.dev) — opcional ---
# Com token, as cotações da carteira vêm da brapi (lote, fonte dedicada à B3);
# sem token, o fallback é o Yahoo Finance (não-oficial). Token gratuito:
#   https://brapi.dev/dashboard
BRAPI_TOKEN=

# --- E-mail transacional (verificação de conta / reset de senha) ---
# Sem MAIL_SERVER, modo DEV: o conteúdo do e-mail (com o link) sai no log.
# Funciona com qualquer SMTP (SendGrid, Mailgun, SES, Gmail c/ app password...).
MAIL_SERVER=
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_USE_TLS=1
MAIL_FROM=

# --- Lembrete mensal de DARF (cron) ---
# Agende no servidor (ex.: dia 1 de cada mês às 09:00):
#   0 9 1 * *  cd /app && flask darf-remind
# Envia para cada usuário o DARF do mês anterior com vencimento (usa MAIL_*).

# --- Importação de notas por e-mail (IMAP) — opcional ---
# O usuário encaminha o e-mail da corretora (PDF anexo) para esta caixa, a
# partir do e-mail cadastrado no app. Agende: */15 * * * * flask import-mail
# Para Gmail, use uma senha de app (myaccount.google.com/apppasswords).
IMPORT_IMAP_HOST=
IMPORT_IMAP_PORT=993
IMPORT_IMAP_USER=
IMPORT_IMAP_PASSWORD=
IMPORT_IMAP_FOLDER=INBOX

# --- Observabilidade (opcional) ---
# Crie um projeto Flask em sentry.io e cole o DSN para receber erros.
SENTRY_DSN=
